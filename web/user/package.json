{
  "name": "user",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "./predev.sh",
    "dev": "nuxt dev --https --ssl-cert ./localhost.pem --ssl-key ./localhost-key.pem",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview --https --ssl-cert ./localhost.pem --ssl-key ./localhost-key.pem",
    "start": "nuxt start",
    "postinstall": "(test -f ../shared/dist/index.js || (cd ../shared && pnpm install && pnpm build)) && nuxt prepare",
    "lint": "eslint .",
    "format": "pnpm lint --fix",
    "test": "vitest --run",
    "coverage": "vitest run --coverage",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@furumaru/shared": "workspace:*",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nuxt/image": "^1.11.0",
    "@nuxtjs/robots": "^5.7.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^9.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/markdown-it": "^13.0.9",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.12.2",
    "dayjs": "^1.11.18",
    "hls.js": "^1.6.13",
    "markdown-it": "^14.1.0",
    "microcms-js-sdk": "^3.2.0",
    "nuxt": "^4.1.3",
    "pinia": "^3.0.4",
    "postcss-custom-properties": "^13.3.12",
    "sass": "^1.93.2",
    "vue3-google-map": "^0.25.0"
  },
  "devDependencies": {
    "@fontsource/stix-two-text": "4.5.16",
    "@fortawesome/fontawesome-free": "6.7.2",
    "@nuxt/eslint": "0.3.13",
    "@nuxt/types": "2.18.1",
    "@nuxtjs/i18n": "10.1.0",
    "@nuxtjs/stylelint-module": "4.2.2",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia-plugin-persistedstate/nuxt": "^1.2.1",
    "@sentry/vite-plugin": "2.23.1",
    "@types/google.maps": "3.58.1",
    "@types/hls.js": "1.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vue/test-utils": "2.4.6",
    "eslint": "9.37.0",
    "eslint-plugin-tailwindcss": "3.18.2",
    "happy-dom": "18.0.1",
    "nuxt-gtag": "2.1.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "vue-tsc": "2.2.12"
  },
  "packageManager": "pnpm@10.12.1"
