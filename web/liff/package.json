{
  "name": "furumaru-web-liff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "(test -f ../shared/dist/index.js || (cd ../shared && pnpm install && pnpm build)) && nuxt prepare",
    "lint": "eslint .",
    "format": "pnpm lint --fix",
